{
  "name": "store-desktop",
  "version": "1.0.0",
  "description": "Application de gestion de boutique d’épices et arômes",
  "author": "Mo-N-Ster",
  "main": "dist/backend/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p backend/tsconfig.json --watch\" \"wait-on tcp:5173 dist/backend/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc -b && vite build && tsc -p backend/tsconfig.json",
    "preview": "vite preview",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "package": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.monster.store",
    "productName": "STORE",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "package.json"],
    "asarUnpack": ["node_modules/better-sqlite3/**/*"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest", "bcryptjs": "latest", "better-sqlite3": "latest", "chart.js": "latest",
    "date-fns": "latest", "i18next": "latest", "jspdf": "latest", "nodemailer": "latest", "react": "18.3.1",
    "react-chartjs-2": "latest", "react-dom": "18.3.1", "react-i18next": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest", "@types/better-sqlite3": "latest", "@types/node": "latest", "@types/nodemailer": "latest",
    "@types/react": "latest", "@types/react-dom": "latest", "concurrently": "latest", "cross-env": "latest",
    "electron": "latest", "electron-builder": "latest", "eslint": "latest", "typescript": "latest",
    "typescript-eslint": "latest", "vite": "latest", "vitest": "latest", "wait-on": "latest"
  }
}
